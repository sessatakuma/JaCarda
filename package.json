{
    "name": "jacarda",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "cards": "bun scripts/generate-vocab-cards.mjs",
        "preview": "vite preview",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "prepare": "husky",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "smoke": "node scripts/smoke-create-hsi-app.mjs",
        "check": "tsc -p tsconfig.json --noEmit && eslint . && prettier . --check && vite build"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,css,scss,html,json,md,yml,yaml}": [
            "prettier --write"
        ],
        "*.{js,jsx,ts,tsx}": [
            "eslint --fix"
        ]
    },
    "dependencies": {
        "i18next": "^26.3.1",
        "lucide-react": "0.554.0",
        "react": "19.2.6",
        "react-dom": "19.2.6",
        "react-i18next": "^17.0.8"
    },
    "devDependencies": {
        "@ianvs/prettier-plugin-sort-imports": "4.7.1",
        "@types/react": "19.2.15",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "6.0.2",
        "complete-lint": "5.11.0",
        "eslint": "10.4.0",
        "eslint-config-complete": "4.7.2",
        "eslint-import-resolver-typescript": "4.4.4",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.7",
        "prettier": "3.8.3",
        "typescript": "6.0.3",
        "vite": "8.0.13"
    },
    "packageManager": "bun@1.3.9"
}
